# Environment variables — copy to `.env` for local dev. NEVER commit `.env`.
# Vars prefixed PUBLIC_ are exposed to the browser (Astro convention).

# --- Phase 6: Forms (Formspree) + bot protection (Cloudflare Turnstile) ---
PUBLIC_FORMSPREE_ENDPOINT=
PUBLIC_TURNSTILE_SITE_KEY=

# --- Phase 7: Cloudflare Pages deploy ---
# These are set as GitHub Actions repository secrets, NOT in this file.
# CF_API_TOKEN=
# CF_ACCOUNT_ID=
