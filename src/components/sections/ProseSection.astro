---
/* ProseSection — heading + markdown body. FROZEN / change-controlled.
   Rendered from a `sections` entry of type "prose"; the body is slotted in. */
import Container from '../primitives/Container.astro';

interface Props {
  heading?: string;
  background?: 'white' | 'surface' | 'ink' | 'red';
}
const { heading, background = 'white' }: Props = Astro.props;

const bgClass = {
  white: 'bg-white text-ink',
  surface: 'bg-surface text-ink',
  ink: 'bg-ink text-white',
  red: 'bg-brand-red text-white',
}[background];
---

<section class:list={['py-8 md:py-10', bgClass]}>
  <Container size="measure">
    {heading && <h2 class="text-h2 font-heading">{heading}</h2>}
    <div class:list={['space-y-3 text-base', heading && 'mt-3']}>
      <slot />
    </div>
  </Container>
</section>
