---
interface Props {
  videoSrc: string;
  tagline: string;
  heading: string;
  description: string;
  ctaLabel: string;
  ctaHref: string;
}

const { videoSrc, tagline, heading, description, ctaLabel, ctaHref }: Props = Astro.props;
---

<section class="hero">
  <video
    class="hero__video"
    src={videoSrc}
    autoplay
    muted
    loop
    playsinline
    aria-hidden="true"
  ></video>

  <div class="hero__overlay" aria-hidden="true"></div>

  <div class="hero__content">
    <div class="hero__inner">
      <p class="hero__tagline">{tagline}</p>
      <h1 class="hero__heading">{heading}</h1>
      <p class="hero__description">{description}</p>
      <a href={ctaHref} class="hero__cta">{ctaLabel}</a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background-color: var(--color-ink);
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  /* Two-layer overlay: solid base + directional gradient for text pop */
  .hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to right,
        rgba(26, 26, 26, 0.75) 0%,
        rgba(26, 26, 26, 0.45) 60%,
        rgba(26, 26, 26, 0.2) 100%
      ),
      linear-gradient(
        to top,
        rgba(26, 26, 26, 0.6) 0%,
        transparent 50%
      );
  }

  .hero__content {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-inline: clamp(1.5rem, 5vw, 4rem);
    padding-block: 8rem 5rem;
  }

  .hero__inner {
    max-width: var(--container-page);
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .hero__tagline {
    font-family: var(--font-heading);
    font-size: var(--text-caption);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-brand-red);
    margin: 0;
  }

  .hero__heading {
    font-family: var(--font-heading);
    font-size: var(--text-display);
    font-weight: 700;
    line-height: var(--text-display--line-height);
    color: var(--color-white);
    max-width: 14ch;
    margin: 0;
    text-wrap: balance;
  }

  .hero__description {
    font-size: var(--text-base);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.8);
    max-width: var(--container-measure);
    margin: 0;
  }

  .hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    background-color: var(--color-brand-red);
    padding: 0.625rem 1.25rem;
    font-family: var(--font-heading);
    font-size: 1.1875rem;
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1;
    color: var(--color-white);
    text-decoration: none;
    transition: background-color 150ms var(--ease-standard);
    margin-top: 0.5rem;
  }

  .hero__cta:hover {
    background-color: var(--color-brand-red-deep);
  }

  /* Pause the video for users who prefer reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .hero__video {
      animation-play-state: paused;
    }
  }
</style>

<script>
  /* Pause the video for users who prefer reduced motion (JS layer) */
  const mq = window.matchMedia('(prefers-reduced-motion: reduce)');
  const video = document.querySelector<HTMLVideoElement>('.hero__video');
  if (video && mq.matches) video.pause();
</script>
