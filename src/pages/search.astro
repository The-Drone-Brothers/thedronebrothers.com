---
/* Search — client-side Pagefind UI. FROZEN / change-controlled.
   The /pagefind/* assets are generated by `pagefind --site dist` after the Astro
   build (see package.json build script), so search works in preview/production,
   not in `astro dev`. */
import BaseLayout from '../layouts/BaseLayout.astro';
import Section from '../components/primitives/Section.astro';
import Container from '../components/primitives/Container.astro';
---

<BaseLayout title="Search" description="Search the Drone Brothers site." noindex>
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css" slot="head" />

  <Section>
    <Container size="measure">
      <h1 class="text-h1 font-heading">Search</h1>
      <div id="search" class="mt-4"></div>
      <noscript>
        <p class="mt-4 text-base text-gray-mid">Search requires JavaScript.</p>
      </noscript>
    </Container>
  </Section>

  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      if (window.PagefindUI) {
        new window.PagefindUI({ element: '#search', showSubResults: true, showImages: false });
      }
    });
  </script>
</BaseLayout>
