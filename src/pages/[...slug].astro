---
/* Dynamic route for the `pages` collection. Catch-all (lowest priority — more
   specific routes like /blog and /styleguide win). FROZEN / change-controlled. */
import { getCollection, render, type CollectionEntry } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import PageLayout from '../layouts/PageLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const entries = await getCollection('pages', ({ data }) => !data.draft);
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
};

const { entry } = Astro.props as { entry: CollectionEntry<'pages'> };
const { Content } = await render(entry);
---

<PageLayout
  title={entry.data.title}
  description={entry.data.description}
  noindex={entry.data.noindex}
  ogImage={entry.data.ogImage}
>
  <Content />
</PageLayout>
