---
/* Blog index — lists `posts`. FROZEN / change-controlled. */
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section from '../../components/primitives/Section.astro';
import Container from '../../components/primitives/Container.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<BaseLayout title="Insights" description="News, case studies, and field notes from Drone Brothers.">
  <Section>
    <Container>
      <h1 class="text-h1 font-heading">Insights</h1>
      {
        posts.length === 0 ? (
          <p class="mt-4 text-base text-gray-mid">No posts yet.</p>
        ) : (
          <ul class="mt-4 space-y-4">
            {posts.map((post) => (
              <li>
                <a href={`/blog/${post.id}`} class="font-heading text-h3 hover:text-brand-red">
                  {post.data.title}
                </a>
                <p class="max-w-measure text-small text-gray-mid">{post.data.description}</p>
              </li>
            ))}
          </ul>
        )
      }
    </Container>
  </Section>
</BaseLayout>
