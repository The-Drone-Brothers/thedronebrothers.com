---
/* ArticleLayout — renders a `posts` collection entry. FROZEN / change-controlled. */
import BaseLayout from './BaseLayout.astro';
import Section from '../components/primitives/Section.astro';
import Container from '../components/primitives/Container.astro';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
}
const { title, description, pubDate, updatedDate, author = 'Drone Brothers' }: Props = Astro.props;
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={title} description={description} ogType="article">
  <Section>
    <Container size="measure">
      <article>
        <h1 class="text-h1 font-heading">{title}</h1>
        <p class="mt-2 text-small text-gray-mid">
          {author} &middot; <time datetime={pubDate.toISOString()}>{fmt(pubDate)}</time>
          {updatedDate && <span> &middot; Updated {fmt(updatedDate)}</span>}
        </p>
        <div class="mt-4 space-y-3 text-base">
          <slot />
        </div>
      </article>
    </Container>
  </Section>
</BaseLayout>
